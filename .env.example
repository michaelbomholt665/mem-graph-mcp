# mem-graph — Environment Configuration
# Copy to .env and edit before starting the server.
# Lines starting with # are comments.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the Ladybug (Kuzu) database directory.
LADYBUG_DB_PATH=./data/syntx_memory.lbug

# ---------------------------------------------------------------------------
# Ollama — embedding models
# ---------------------------------------------------------------------------

# Jina v4 is specialized for code (use for 'audit', 'map', 'triage').
# Primary: hf.co/jinaai/jina-embeddings-v4-text-code-GGUF:Q5_K_M
# Fallback: hf.co/jinaai/jina-embeddings-v4-text-code-GGUF:IQ4_NL
OLLAMA_CODE_EMBED_MODEL=hf.co/jinaai/jina-embeddings-v4-text-code-GGUF:Q5_K_M

# Nomic v1.5 is general purpose (use for 'memory', 'notes', 'tasks').
OLLAMA_TEXT_EMBED_MODEL=hf.co/nomic-ai/nomic-embed-text-v1.5-GGUF:F16

# Embedding dimension (both models use 768).
OLLAMA_EMBED_DIM=768

# How long Ollama should keep models loaded (5m recommended).
OLLAMA_KEEP_ALIVE=5m

# Lightweight model used for conversation summarisation.
OLLAMA_SUMMARISE_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Transport: http (default) | stdio | sse | streamable-http
MCP_TRANSPORT=http

# Host and port when MCP_TRANSPORT=http.
MCP_HOST=127.0.0.1
MCP_PORT=9100

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Authentication (optional)
# ---------------------------------------------------------------------------

# Comma-separated list of valid Bearer tokens.
# When unset, authentication is disabled (local-only default).
# When set, all requests must include: Authorization: Bearer <key>
# MEM_GRAPH_API_KEYS=changeme,anotherkey

# ---------------------------------------------------------------------------
# Agent model (for audit_agent)
# ---------------------------------------------------------------------------

# Pydantic AI model string for the autonomous audit agent.
# Must be a model your environment has credentials for.
# Examples: openai:gpt-4o, anthropic:claude-sonnet-4-6
MEM_GRAPH_AGENT_MODEL=openai:gpt-4o

# ---------------------------------------------------------------------------
# Ollama server location (for health endpoint check)
# ---------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
